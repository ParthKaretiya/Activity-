{
  "manifest_version": 3,
  "name": "Simple Habit Tracker",
  "version": "1.0",
  "action": {
    "default_popup": "index.html",
    "default_title": "Track Habit",
    "default_icon": {
        "16": "oggy1.png",
        "48": "oggy1.png",
        "128": "oggy1.png"
    }
  },
  "icons": {
      "16": "oggy1.png",
      "48": "oggy1.png",
      "128": "oggy1.png"
  },
  "permissions": ["storage"]
}